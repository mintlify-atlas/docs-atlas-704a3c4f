{
  "$schema": "https://mintlify.com/docs.json",
  "name": "OpenCode Portal",
  "theme": "palm",
  "colors": {
    "primary": "#0ea5e9",
    "light": "#38bdf8",
    "dark": "#0284c7"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/hosenur/portal"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/hosenur/portal"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Installation",
            "pages": [
              "installation/local",
              "installation/remote",
              "installation/docker"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/sessions",
              "features/chat-interface",
              "features/git-integration",
              "features/file-mentions",
              "features/instance-management"
            ]
          },
          {
            "group": "CLI Reference",
            "pages": [
              "cli/overview",
              "cli/commands",
              "cli/options"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/mobile-access",
              "guides/tailscale-setup",
              "guides/multiple-projects",
              "guides/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Server API",
            "pages": [
              "api/overview",
              "api/sessions",
              "api/git",
              "api/files",
              "api/instances"
            ]
          }
        ]
      }
    ]
  }
}
